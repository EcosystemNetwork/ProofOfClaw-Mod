# Frontend — static files served by nginx
FROM nginx:alpine

# Remove default nginx site
RUN rm -rf /usr/share/nginx/html/* /etc/nginx/conf.d/default.conf

# Copy static frontend files
COPY frontend/ /usr/share/nginx/html/

# Copy nginx configuration
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

# Production hardening: nginx:alpine runs as root by default to bind port 80.
# For production, consider using port 8080 with a non-root user or
# the nginxinc/nginx-unprivileged image.

# nginx runs on port 80 inside the container
EXPOSE 80

HEALTHCHECK --interval=15s --timeout=3s --start-period=5s --retries=3 \
    CMD wget -qO- http://localhost/nginx-health || exit 1
